    <script>
    window.haminosTrackClick=function(event,handle,title,url){const webhookUrl="https://haminos-ecom-n8n.5pbmxd.easypanel.host/webhook/1e929533-3402-4e43-a65d-2a0333380cf0/chat";fetch(webhookUrl,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({action:"track",event:event,sessionId:localStorage.getItem("haminos_chat_session")||"",productHandle:handle,productTitle:title,productUrl:url,timestamp:new Date().toISOString(),page:window.location.href})}).catch(()=>{});};
    window.haminosViewProduct=function(handle,title,url){haminosTrackClick("view_product",handle,title,url);window.open(url,"_blank");};
    window.haminosAddToCart=async function(handle,title){haminosTrackClick("add_to_cart",handle,title||"","");if(!handle)return;try{const t=await fetch("/products/"+handle+".js");if(!t.ok)throw new Error("Producto no encontrado");const o=await t.json(),n=o.variants[0]?.id;if(!n)throw new Error("No se encontró variante");const a=await fetch("/cart/add.js",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({items:[{id:n,quantity:1}]})});if(!a.ok)throw new Error("Error al añadir");sessionStorage.setItem("haminos_chat_was_open","true");sessionStorage.setItem("haminos_show_cart_btn","true");window.location.reload();}catch(e){alert("No se pudo añadir el producto al carrito.")}};
    window.haminosShowCartButton=function(){const messagesContainer=document.getElementById("haminosChatMessages");if(!messagesContainer||document.querySelector(".haminos-cart-btn"))return;const btn=document.createElement("a");btn.href="/cart";btn.className="haminos-cart-btn";btn.innerHTML='<svg viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>Ir al carrito';btn.onclick=function(){sessionStorage.removeItem("haminos_show_cart_btn");};messagesContainer.appendChild(btn);messagesContainer.scrollTop=messagesContainer.scrollHeight;};
    const haminosNotifStyle=document.createElement("style");haminosNotifStyle.textContent="@keyframes haminosFadeIn{from{opacity:0;transform:translateX(-50%) translateY(10px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}@keyframes haminosFadeOut{from{opacity:1;transform:translateX(-50%) translateY(0)}to{opacity:0;transform:translateX(-50%) translateY(10px)}}",document.head.appendChild(haminosNotifStyle);
    (function(){"use strict";

    const CONFIG={webhookUrl:"https://haminos-ecom-n8n.5pbmxd.easypanel.host/webhook/1e929533-3402-4e43-a65d-2a0333380cf0/chat",sessionKey:"haminos_chat_session",historyKey:"haminos_chat_history",maxHistoryAge:7*24*60*60*1000};
    const t=document.getElementById("haminosChatToggle"),o=document.getElementById("haminosChatWindow"),n=document.getElementById("haminosChatMessages"),a=document.getElementById("haminosChatInput"),s=document.getElementById("haminosSendBtn"),i=document.getElementById("haminosWelcomeScreen"),r=document.getElementById("haminosHeaderClose");
    if(sessionStorage.getItem("haminos_chat_was_open")==="true"){sessionStorage.removeItem("haminos_chat_was_open");setTimeout(()=>{o.classList.add("open");t.classList.add("open");},100);}
    if(sessionStorage.getItem("haminos_show_cart_btn")==="true"){setTimeout(()=>{window.haminosShowCartButton();},200);}
    let sessionId=localStorage.getItem(CONFIG.sessionKey)||function(){const id="haminos_"+Date.now()+"_"+Math.random().toString(36).substr(2,9);localStorage.setItem(CONFIG.sessionKey,id);return id}();
    let isLoading=false;
    let chatHistory=[];

    function loadHistory(){
        try{
            const saved=localStorage.getItem(CONFIG.historyKey);
            if(saved){
                const data=JSON.parse(saved);
                if(data.timestamp&&Date.now()-data.timestamp<CONFIG.maxHistoryAge){
                    chatHistory=data.messages||[];
                    return true;
                }else{
                    localStorage.removeItem(CONFIG.historyKey);
                }
            }
        }catch(e){}
        return false;
    }

    function saveHistory(){
        try{
            localStorage.setItem(CONFIG.historyKey,JSON.stringify({timestamp:Date.now(),messages:chatHistory}));
        }catch(e){}
    }

    function restoreMessages(){
        if(chatHistory.length>0){
            i.style.display="none";
            chatHistory.forEach(msg=>{
                createBubble(msg.content,msg.sender,true);
            });
            n.scrollTop=n.scrollHeight;
            setTimeout(()=>{n.querySelectorAll('.haminos-products-container').forEach(c=>{if(!c.dataset.navInit){c.dataset.navInit='1';initCarouselNav(c);}});},100);
        }
    }

    function initCarouselNav(container){
        const grid=container.querySelector('.haminos-products-grid');
        const cards=grid.querySelectorAll('.haminos-product-card');
        const dots=container.querySelectorAll('.haminos-carousel-dot');
        if(cards.length<=1)return;
        const prevBtn=document.createElement('button');
        prevBtn.className='haminos-carousel-nav prev';
        prevBtn.innerHTML='<svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>';
        const nextBtn=document.createElement('button');
        nextBtn.className='haminos-carousel-nav next';
        nextBtn.innerHTML='<svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>';
        container.style.position='relative';
        container.insertBefore(prevBtn,grid);
        container.insertBefore(nextBtn,grid.nextSibling);
        let currentIndex=0;
        function scrollToCard(idx){
            if(idx<0)idx=0;
            if(idx>=cards.length)idx=cards.length-1;
            currentIndex=idx;
            cards[idx].scrollIntoView({behavior:'smooth',block:'nearest',inline:'start'});
            dots.forEach((d,j)=>d.classList.toggle('active',j===idx));
        }
        prevBtn.addEventListener('click',()=>scrollToCard(currentIndex-1));
        nextBtn.addEventListener('click',()=>scrollToCard(currentIndex+1));
        dots.forEach((dot,idx)=>{dot.addEventListener('click',()=>scrollToCard(idx));});
        grid.addEventListener('scroll',()=>{
            const scrollLeft=grid.scrollLeft;
            const cardWidth=cards[0].offsetWidth+12;
            const newIndex=Math.round(scrollLeft/cardWidth);
            if(newIndex!==currentIndex){currentIndex=newIndex;dots.forEach((d,j)=>d.classList.toggle('active',j===currentIndex));}
        });
    }

    function addMessage(content,sender,skipSave){
        if(sender==="bot"){
            splitBotMessage(content).forEach(part=>{if(part.trim()){createBubble(part,sender,skipSave);}});
        }else{
            createBubble(content,sender,skipSave);
        }
        n.scrollTop=n.scrollHeight;
        setTimeout(()=>{n.querySelectorAll('.haminos-products-container').forEach(c=>{if(!c.dataset.navInit){c.dataset.navInit='1';initCarouselNav(c);}});},100);
    }

    function splitBotMessage(content){
        // Check if content contains a JSON product block
        const hasProduct = content.includes("[PRODUCT]") && content.includes("[/PRODUCT]");
        
        if(hasProduct){
            const parts=[];
            const productStart = content.indexOf("[PRODUCT]");
            const productEnd = content.lastIndexOf("[/PRODUCT]") + 10; // length of [/PRODUCT]
            
            // Get intro text before the product
            const introText = content.substring(0, productStart).trim();
            if(introText){
                introText.split(/\\n|\n\n|\n/).filter(s=>s.trim()).forEach(p=>parts.push(p.trim()));
            }
            
            // The product block (includes all products between the first and last tags)
            const productBlock = content.substring(productStart, productEnd);
            parts.push(productBlock);
            
            // Text after the last product block
            let afterProduct = content.substring(productEnd).trim();
            afterProduct = afterProduct.replace(/^\\n|^\n/,"").trim();
            if(afterProduct){
                afterProduct.split(/\\n|\n\n|\n/).filter(s=>s.trim()).forEach(p=>parts.push(p.trim()));
            }
            
            return parts.filter(p=>p.length>0);
        }
        
        // No product - split by newlines (both escaped \\n and actual \n)
        return content.split(/\\n|\n\n|\n/).map(s=>s.trim()).filter(s=>s.length>0);
    }

    function createBubble(content,sender,skipSave){
        const div=document.createElement("div");
        div.className="haminos-message "+sender;
        const contentDiv=document.createElement("div");
        contentDiv.className="haminos-message-content";
        contentDiv.innerHTML=parseContent(content);
        // Attach WhatsApp button click handlers (using spans to avoid Shopify/Transcy stripping <a> tags)
        contentDiv.querySelectorAll('.haminos-whatsapp-btn[data-wa-url]').forEach(function(btn){
            btn.addEventListener('click', function(){ window.open(btn.getAttribute('data-wa-url'), '_blank'); });
        });
        div.appendChild(contentDiv);
        n.appendChild(div);
        if(!skipSave){
            chatHistory.push({content:content,sender:sender});
            saveHistory();
        }
    }

    function parseContent(content){
        let html=parseMarkdown(content);
        html=convertTrackingToButtons(html);
        return convertProductsToCards(html);
    }



    function convertTrackingToButtons(html){
        const trackingDomains=[
            'cttexpress.com','seur.com','dpd.com','dpd.es','gls-spain.es','gls-group.eu',
            'mrw.es','correosexpress.com','correos.es','nacex.es','sending.es','tipsa.com',
            'dhl.com','dhl.es','ups.com','fedex.com','envialia.com','colissimo','laposte.fr',
            '17track.net','aftership.com','trackingmore.com','parcelmonitor.com'
        ];
        const urlRegex=/(https?:\/\/[^\s<>"]+)/gi;
        return html.replace(urlRegex, function(url){
            const isTracking=trackingDomains.some(d=>url.toLowerCase().includes(d));
            if(isTracking){
                return `<a href="${url}" target="_blank" class="haminos-tracking-btn"><svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>Ver seguimiento</a>`;
            }
            return url;
        });
    }

    function parseMarkdown(text){
        if(!text)return"";
        let h=text;
        // Remove horizontal rules
        h=h.replace(/\n---\n/g,"\n");
        h=h.replace(/^---$/gm,"");
        h=h.replace(/---/g,"");
        // First, process markdown BEFORE escaping (order matters!)
        // IMPORTANT: Use %%..%% instead of {{ }} to avoid Liquid template engine conflicts
        // Images: ![alt](url) - use §§ as separator to avoid conflicts with : in URLs
        h=h.replace(/!\[(.*?)\]\((.*?)\)/g,'%%IMG§§$2§§$1%%');
        // Links: [text](url)
        h=h.replace(/\[(.*?)\]\((.*?)\)/g,'%%LINK§§$2§§$1%%');
        // Bold: **text**
        h=h.replace(/\*\*(.*?)\*\*/g,'%%BOLD§§$1%%');
        // Italic: *text*
        h=h.replace(/\*(.*?)\*/g,'%%ITALIC§§$1%%');
        // Now escape any remaining HTML-like characters
        h=h.replace(/</g,"&lt;").replace(/>/g,"&gt;");
        // Restore markdown elements as HTML
        h=h.replace(/%%IMG§§(.*?)§§(.*?)%%/g,'<img src="$1" alt="$2" style="max-width:100%;border-radius:8px;margin:8px 0;">');
        // Restore links — detect wa.me and output as <span> button (not <a>) to avoid Shopify/Transcy stripping
        h=h.replace(/%%LINK§§(.*?)§§(.*?)%%/g, function(m,url,txt){
            if(url.indexOf('wa.me')!==-1){
                return '<span class="haminos-whatsapp-btn" data-wa-url="'+url+'">'+txt+'</span>';
            }
            return '<a href="'+url+'" target="_blank">'+txt+'</a>';
        });
        // Fallback: catch bare wa.me URLs not in markdown link format
        h=h.replace(/(^|[\s>])(https?:\/\/wa\.me\/[^\s<"]+)/gi, function(m,pre,url){
            return pre+'<span class="haminos-whatsapp-btn" data-wa-url="'+url+'">Abrir WhatsApp</span>';
        });
        h=h.replace(/%%BOLD§§(.*?)%%/g,'<strong>$1</strong>');
        h=h.replace(/%%ITALIC§§(.*?)%%/g,'<em>$1</em>');
        // Line breaks
        h=h.replace(/\\n/g,"<br>");
        h=h.replace(/\n/g,"<br>");
        // Clean up multiple breaks
        h=h.replace(/(<br>\s*)+---\s*(<br>\s*)+/gi,"<br>");
        // Paragraphs
        if(h.split("<br><br>").length>1){h=h.split("<br><br>").map(p=>"<p>"+p+"</p>").join("");}
        return h;
    }

    function convertProductsToCards(text){
        // Look for all [PRODUCT]JSON[/PRODUCT] patterns
        const matches = [...text.matchAll(/\[PRODUCT\](.*?)\[\/PRODUCT\]/gs)];
        if(matches.length === 0) return text;
        
        let productsHtml = '<div class="haminos-products-container"><div class="haminos-products-grid">';
        let hasValidProduct = false;
        
        matches.forEach(match => {
            try {
                const jsonStr = match[1].trim();
                const p = JSON.parse(jsonStr);
                
                // Extract handle from URL
                const handleMatch = p.url ? p.url.match(/\/products\/([^/?#]+)/) : null;
                const handle = handleMatch ? handleMatch[1] : "";
                
                hasValidProduct = true;
                productsHtml += '<div class="haminos-product-card">';
                productsHtml += '<img class="haminos-product-card-image" src="' + esc(p.img) + '" alt="' + esc(p.title) + '" onerror="this.style.display=\'none\'">';
                productsHtml += '<div class="haminos-product-card-body">';
                productsHtml += '<h4 class="haminos-product-card-title">' + esc(p.title) + '</h4>';
                productsHtml += '<div class="haminos-product-card-price">' + esc(p.price) + '</div>';
                productsHtml += '<p class="haminos-product-card-description">' + esc(p.desc) + '</p>';
                productsHtml += '<div class="haminos-product-card-buttons">';
                productsHtml += '<button onclick="haminosViewProduct(\'' + esc(handle) + '\',\'' + esc(p.title).replace(/'/g,"\\'") + '\',\'' + esc(p.url) + '\')" class="haminos-product-card-btn primary">Ver producto</button>';
                productsHtml += '<button onclick="haminosAddToCart(\'' + esc(handle) + '\',\'' + esc(p.title).replace(/'/g,"\\'") + '\')" class="haminos-product-card-btn secondary">Añadir al carrito</button>';
                productsHtml += '</div></div></div>';
            } catch(e) {
                console.error("Error parsing product JSON:", e);
            }
        });
        
        productsHtml += "</div>";
        
        // Add dots if more than one product
        if (matches.length > 1) {
            productsHtml += '<div class="haminos-carousel-dots">';
            matches.forEach((_, idx) => {
                productsHtml += `<button class="haminos-carousel-dot ${idx === 0 ? 'active' : ''}" data-index="${idx}"></button>`;
            });
            productsHtml += '</div>';
        }
        
        productsHtml += "</div>";
        
        // Replace the entire block that contained products
        // We replace the text from the first match to the last match
        const firstMatch = matches[0];
        const lastMatch = matches[matches.length - 1];
        const fullBlockStart = text.indexOf(firstMatch[0]);
        const fullBlockEnd = text.lastIndexOf(lastMatch[0]) + lastMatch[0].length;
        
        if(!hasValidProduct) return text;
        
        return text.substring(0, fullBlockStart) + productsHtml + text.substring(fullBlockEnd);
    }

    function esc(text){if(!text)return"";const d=document.createElement("div");d.textContent=text;return d.innerHTML;}

    t.addEventListener("click",()=>{const isOpen=o.classList.toggle("open");t.classList.toggle("open",isOpen);if(isOpen&&i.style.display==="none")a.focus();});
    r.addEventListener("click",()=>{o.classList.remove("open");t.classList.remove("open");});
    document.querySelectorAll(".haminos-quick-action-btn").forEach(btn=>{btn.addEventListener("click",()=>{i.style.display="none";sendMessage(btn.dataset.message);});});
    s.addEventListener("click",()=>{const msg=a.value.trim();if(msg&&!isLoading)sendMessage(msg);});
    a.addEventListener("keypress",e=>{if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();const msg=a.value.trim();if(msg&&!isLoading)sendMessage(msg);}});
    a.addEventListener("input",()=>{a.style.height="auto";a.style.height=Math.min(a.scrollHeight,100)+"px";});

    async function sendMessage(message){
        if(isLoading)return;
        a.value="";a.style.height="auto";
        if(i.style.display!=="none")i.style.display="none";
        addMessage(message,"user");
        isLoading=true;s.disabled=true;
        const typing=document.createElement("div");
        typing.className="haminos-typing-indicator";
        typing.innerHTML="<span></span><span></span><span></span>";
        n.appendChild(typing);n.scrollTop=n.scrollHeight;
        try{
            const res=await fetch(CONFIG.webhookUrl,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({chatInput:message,sessionId:sessionId,action:"sendMessage"})});
            if(!res.ok)throw new Error("Error");
            const data=await res.json();
            typing.remove();
            addMessage(data.output||data.text||data.message||"Lo siento, ha ocurrido un error.","bot");
        }catch(e){typing.remove();addMessage("Lo siento, ha ocurrido un error. Por favor, intenta de nuevo.","bot");}
        finally{isLoading=false;s.disabled=false;}
    }

    document.addEventListener("keydown",e=>{if(e.key==="Escape"&&o.classList.contains("open")){o.classList.remove("open");t.classList.remove("open");}});

    if(loadHistory()){restoreMessages();}
    })();
    </script>

